<?xml version="1.0"?>

<sdf version="1.10">

<model name="busbar_b">

  <static>true</static>

  <link name="link">

    <!-- ===================== -->
    <!-- MAIN ALUMINUM BUSBAR -->
    <!-- ===================== -->

    <visual name="busbar_b_main">
      <geometry>
        <box>
          <size>10 0.4 0.4</size>
        </box>
      </geometry>
      <material>
        <ambient>0.72 0.74 0.76 1</ambient>
        <diffuse>0.82 0.84 0.86 1</diffuse>
        <specular>0.45 0.45 0.45 1</specular>
      </material>
    </visual>

    <!-- Busbar grooves for realism -->
    <visual name="busbar_b_groove_1">
      <pose>0 0 -0.15 0 0 0</pose>
      <geometry>
        <box>
          <size>10 0.35 0.05</size>
        </box>
      </geometry>
      <material>
        <ambient>0.7 0.7 0.7 1</ambient>
        <diffuse>0.8 0.8 0.8 1</diffuse>
      </material>
    </visual>

    <visual name="busbar_b_groove_2">
      <pose>0 0 0.15 0 0 0</pose>
      <geometry>
        <box>
          <size>10 0.35 0.05</size>
        </box>
      </geometry>
      <material>
        <ambient>0.7 0.7 0.7 1</ambient>
        <diffuse>0.8 0.8 0.8 1</diffuse>
      </material>
    </visual>

    <!-- ===================== -->
    <!-- LEFT ANCHOR CLAMP -->
    <!-- ===================== -->

    <visual name="left_clamp_main">
      <pose>-5 0 0 0 0 0</pose>
      <geometry>
        <box>
          <size>0.3 0.5 0.5</size>
        </box>
      </geometry>
      <material>
        <ambient>0.5 0.5 0.5 1</ambient>
        <diffuse>0.6 0.6 0.6 1</diffuse>
      </material>
    </visual>

    <visual name="left_clamp_screw">
      <pose>-5.15 0.15 0 0 0 0</pose>
      <geometry>
        <cylinder>
          <radius>0.04</radius>
          <length>0.2</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.4 0.4 0.4 1</ambient>
        <diffuse>0.5 0.5 0.5 1</diffuse>
      </material>
    </visual>

    <!-- ===================== -->
    <!-- RIGHT ANCHOR CLAMP -->
    <!-- ===================== -->

    <visual name="right_clamp_main">
      <pose>5 0 0 0 0 0</pose>
      <geometry>
        <box>
          <size>0.3 0.5 0.5</size>
        </box>
      </geometry>
      <material>
        <ambient>0.5 0.5 0.5 1</ambient>
        <diffuse>0.6 0.6 0.6 1</diffuse>
      </material>
    </visual>

    <visual name="right_clamp_screw">
      <pose>5.15 0.15 0 0 0 0</pose>
      <geometry>
        <cylinder>
          <radius>0.04</radius>
          <length>0.2</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.4 0.4 0.4 1</ambient>
        <diffuse>0.5 0.5 0.5 1</diffuse>
      </material>
