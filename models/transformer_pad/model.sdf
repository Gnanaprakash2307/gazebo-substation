      <!-- ===================== -->
      <!-- IDENTIFICATION MARKING -->
      <!-- ===================== -->
      <visual name="marking_area">
        <pose>0 2.05 0.48 0 0 0</pose>
        <geometry>
          <box>
            <size>1.5 0.08 0.3</size>
          </box>
        </geometry>
        <material>
          <ambient>1 1 0.8 1</ambient>
          <diffuse>1 1 0.9 1</diffuse>
        </material>
      </visual>

      <!-- ===================== -->
      <!-- OIL RETENTION BORDER -->
      <!-- ===================== -->
      <visual name="drain_sump">
        <pose>0 0 -0.1 0 0 0</pose>
        <geometry>
