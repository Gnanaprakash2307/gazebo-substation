      </geometry>
      <material>
        <ambient>0.55 0.55 0.55 1</ambient>
        <diffuse>0.65 0.65 0.65 1</diffuse>
      </material>
    </visual>

    <!-- ===================== -->
    <!-- PHASE IDENTIFICATION BAND -->
    <!-- (Color applied via world file) -->
    <!-- Red=Phase A, Yellow=Phase B, Blue=Phase C -->
    <!-- ===================== -->

    <visual name="phase_id_band">
      <pose>4.5 0 0.25 0 0 0</pose>
      <geometry>
        <box>
          <size>0.8 0.6 0.8</size>
        </box>
      </geometry>
      <material>
        <ambient>0.85 0.65 0.1 1</ambient>
        <diffuse>1.0 0.8 0.15 1</diffuse>
        <specular>0.3 0.3 0.3 1</specular>
      </material>
    </visual>

    <!-- ===================== -->
    <!-- COLLISION -->
    <!-- ===================== -->

    <collision name="collision">
      <geometry>
        <box>
          <size>10 0.4 0.4</size>
        </box>
      </geometry>
    </collision>

  </link>

</model>

</sdf>