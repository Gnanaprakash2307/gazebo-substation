    <!-- INTERMEDIATE SUPPORTS -->
    <!-- ===================== -->

    <visual name="mid_support_1">
      <pose>-3.3 0 0 0 0 0</pose>
      <geometry>
        <box>
          <size>0.15 0.3 0.3</size>
        </box>
      </geometry>
      <material>
        <ambient>0.55 0.55 0.55 1</ambient>
        <diffuse>0.65 0.65 0.65 1</diffuse>
      </material>
    </visual>

    <visual name="mid_support_2">
      <pose>-1.65 0 0 0 0 0</pose>
      <geometry>
        <box>
          <size>0.15 0.3 0.3</size>
        </box>
      </geometry>
      <material>
        <ambient>0.55 0.55 0.55 1</ambient>
        <diffuse>0.65 0.65 0.65 1</diffuse>
      </material>
    </visual>

    <visual name="mid_support_3">
      <pose>0 0 0 0 0 0</pose>
      <geometry>
        <box>
          <size>0.15 0.3 0.3</size>
        </box>
      </geometry>
      <material>
        <ambient>0.55 0.55 0.55 1</ambient>
        <diffuse>0.65 0.65 0.65 1</diffuse>
      </material>
    </visual>

    <visual name="mid_support_4">
      <pose>1.65 0 0 0 0 0</pose>
      <geometry>
        <box>
          <size>0.15 0.3 0.3</size>
        </box>
      </geometry>
      <material>
        <ambient>0.55 0.55 0.55 1</ambient>
        <diffuse>0.65 0.65 0.65 1</diffuse>
      </material>
